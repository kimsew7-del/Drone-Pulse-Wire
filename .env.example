# Briefwave Configuration

# Domain (Caddy will auto-issue HTTPS cert via Let's Encrypt)
DOMAIN=briefwave.example.com

# JWT Secret (CHANGE THIS IN PRODUCTION — use: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# External API Keys
NEWSAPI_KEY=
GNEWS_API_KEY=
CROSSREF_MAILTO=you@example.com
KCI_API_KEY=

# Translation
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
PAPAGO_CLIENT_ID=
PAPAGO_CLIENT_SECRET=
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# Database (default: SQLite file in data/)
DATABASE_URL=sqlite+aiosqlite:///./data/briefwave.db
